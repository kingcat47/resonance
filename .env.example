# API
VITE_API_URL=http://localhost:3001

# OPRF 서버 비밀키 — 64자리 hex
# 생성: node -e "const {ristretto255_oprf}=require('@noble/curves/ed25519'); console.log(Buffer.from(ristretto255_oprf.oprf.generateKeyPair().secretKey).toString('hex'))"
# ⚠ 이 값이 바뀌면 기존 신고의 K가 달라져 복호화 불가
OPRF_SECRET_KEY=

# 감독기관 RSA-OAEP 공개키 (JWK JSON) — 실제 배포 시 설정
# 미설정 시 localStorage 데모 키 사용
# 키 생성: 브라우저 콘솔에서 아래 실행
#   const pair = await crypto.subtle.generateKey(
#     {name:"RSA-OAEP",modulusLength:2048,publicExponent:new Uint8Array([1,0,1]),hash:"SHA-256"},
#     true, ["encrypt","decrypt"]
#   );
#   console.log("PUBLIC(env):", JSON.stringify(await crypto.subtle.exportKey("jwk", pair.publicKey)));
#   console.log("PRIVATE(감독기관 보관):", JSON.stringify(await crypto.subtle.exportKey("jwk", pair.privateKey)));
VITE_SUPERVISOR_PUBLIC_KEY=
